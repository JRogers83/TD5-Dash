#!/bin/sh
# TD5 Dash — Chromium kiosk X session
# Launched by startx from ~/.bash_profile on tty1.

# ── Display rotation ───────────────────────────────────────────────────────────
# Read DISPLAY_ROTATION from .env (degrees: 0, 90, 180, 270; default 270).
# Applied via xrandr for the X11 session.  The video= kernel parameter in
# cmdline.txt handles console/Plymouth rotation separately.
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_DIR="$(dirname "$SCRIPT_DIR")"
_rot=270
if [ -f "$REPO_DIR/.env" ]; then
    _val=$(grep '^DISPLAY_ROTATION=' "$REPO_DIR/.env" 2>/dev/null | head -1 | cut -d= -f2 | tr -cd '0-9')
    [ -n "$_val" ] && _rot="$_val"
fi
case "$_rot" in
    90)  _xrot="right"    ;;
    180) _xrot="inverted" ;;
    270) _xrot="left"     ;;
    *)   _xrot="normal"   ;;
esac
xrandr --output DSI-2 --rotate "$_xrot" 2>/dev/null || true

# Set root window to black immediately — prevents the default white X
# background from flashing before Chromium paints.
xsetroot -solid black 2>/dev/null || true

# Touch coordinate transform is handled by /etc/X11/xorg.conf.d/40-touch-rotation.conf
# (written by setup.sh based on DISPLAY_ROTATION in .env)

# Disable screen blanking and power management
xset -dpms
xset s off
xset s noblank

# ── Hide cursor ──────────────────────────────────────────────────────────────
# CSS cursor:none handles it inside Chromium's content area.
# unclutter handles it at the X server level as a catch-all.
unclutter -idle 0 -root &

# Wait for the FastAPI backend to become ready (max ~60 s).
# Poll /health rather than / — /health returns 200 only after lifespan
# has completed startup (db init, service tasks created), not just when
# the static file server is mounted.
i=0
until curl -sf http://localhost:8000/health >/dev/null 2>&1; do
    sleep 0.5
    i=$((i + 1))
    [ $i -ge 120 ] && break
done

exec chromium \
    --kiosk \
    --disk-cache-size=1 \
    --window-position=0,0 \
    --window-size=1280,400 \
    --force-dark-mode \
    --touch-events=enabled \
    --disable-pinch \
    --overscroll-history-navigation=0 \
    --noerrdialogs \
    --disable-infobars \
    --disable-session-crashed-bubble \
    --no-first-run \
    --disable-translate \
    --disable-features=TranslateUI \
    --check-for-update-interval=31536000 \
    --use-fake-ui-for-media-stream \
    http://localhost:8000
