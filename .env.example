# TD5 Dash — environment variable reference
#
# Copy this file to .env and fill in the values.
# .env is loaded automatically by Docker Compose and is git-ignored (keep it local).
#
# ── Mock toggles ───────────────────────────────────────────────────────────────
#
# Each service has a mock mode that returns static placeholder data so you can
# run and develop the dashboard without any physical hardware or credentials.
#
#   1 = mock data    (default — safe to use in Docker on your dev machine)
#   0 = real service (requires the credentials / hardware described below)
#
# Flip individual toggles to 0 as you bring each real service online.

TD5_MOCK=1
VICTRON_MOCK=1
STARLINK_MOCK=1
WEATHER_MOCK=1
SPOTIFY_MOCK=1

# ── Spotify ─────────────────────────────────────────────────────────────────────
#
# Required when SPOTIFY_MOCK=0.
#
# Step 1 — Create a Spotify Developer application:
#   https://developer.spotify.com/dashboard
#   → Add redirect URI: http://localhost:8888/callback
#
# Step 2 — Copy the Client ID and Client Secret from the app dashboard into the
#   vars below.
#
# Step 3 — Run the one-time auth helper to obtain the refresh token:
#   SPOTIFY_CLIENT_ID=... SPOTIFY_CLIENT_SECRET=... python tools/spotify_auth_setup.py
#   A browser window will open.  After you approve, the script prints the token.
#
# The refresh token is long-lived.  It only needs to be regenerated if you
# revoke access in your Spotify account settings.

SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=

# ── Weather ──────────────────────────────────────────────────────────────────────
#
# Required when WEATHER_MOCK=0.
# Uses the free Open-Meteo API — no API key needed, just coordinates.
#
# WEATHER_LAT / WEATHER_LON  Decimal degrees.  Positive = N/E, negative = S/W.
#                            These values seed the SQLite database on first run only.
#                            After that, location is updated from live GPS or the
#                            Setup wizard. Changing these after first run has no effect.
# WEATHER_LOCATION           Human-readable place name (same seeding behaviour).

WEATHER_LAT=52.6309
WEATHER_LON=1.2974
WEATHER_LOCATION=Norwich, UK

# ── Victron BLE ──────────────────────────────────────────────────────────────────
#
# Required when VICTRON_MOCK=0.
# Devices communicate over Bluetooth Low Energy using Victron's encrypted
# advertisement protocol.
#
# MAC addresses   Colon-separated lowercase hex, e.g. aa:bb:cc:dd:ee:ff
#                 Found in the Victron Connect app → device → three-dot menu
#                 → Product info.
#
# Encryption keys 32-character hex string.
#                 Found in Victron Connect → device → three-dot menu
#                 → Product info → Encryption key.  Enable it first if not shown.
#
# Each of the three Victron devices is configured independently.  Leave a
# MAC/KEY pair blank to disable that device (the service will skip it).
#
#   VICTRON_SHUNT_*   SmartShunt 500A — battery current, voltage, SoC
#   VICTRON_MPPT_*    SmartSolar MPPT — solar charge controller, yield
#   VICTRON_ORION_*   Orion XS DC-DC  — alternator-to-leisure battery charger

VICTRON_SHUNT_MAC=
VICTRON_SHUNT_KEY=
VICTRON_MPPT_MAC=
VICTRON_MPPT_KEY=
VICTRON_ORION_MAC=
VICTRON_ORION_KEY=

# ── Pi / deploy only ──────────────────────────────────────────────────────────
#
# These variables are read by deploy/setup.sh and written into boot config.
# They are NOT used at runtime by the backend.
# Change a value here, then re-run sudo ./deploy/setup.sh and reboot.
#
# DISPLAY_ROTATION       Framebuffer rotation for the Waveshare 7.9" DSI panel.
#                        The panel is physically 400x1280 portrait; rotation maps
#                        it to 1280x400 landscape for the kiosk.
#                          270 = default (power cable enters from the bottom)
#                           90 = flipped 180° relative to default
#                        Default: 270
#
# DEFENDER_DEVICE_NAME   Name shown in the Spotify device picker.
#                        Default: Defender

DISPLAY_ROTATION=270

# ── Advanced service tuning ──────────────────────────────────────────────────
#
# These have sensible defaults and rarely need changing.

# SYSTEM_MOCK             1 = static system data (for Docker UI work)
#                         0 = real CPU temp, backlight, Wi-Fi/BT (default)
# SYSTEM_MOCK=0

# TD5_FTDI_URL            PyFtdi device URL for the KKL cable
#                         Default: ftdi://ftdi:232/1
# TD5_FTDI_URL=ftdi://ftdi:232/1

# TD5_POLL_INTERVAL       Seconds between OBD poll cycles
#                         Default: 1.0
# TD5_POLL_INTERVAL=1.0

# STARLINK_HOST           Starlink dish gRPC address
#                         Default: 192.168.100.1
# STARLINK_HOST=192.168.100.1

# STARLINK_POLL_INTERVAL  Seconds between Starlink polls
#                         Default: 2.0
# STARLINK_POLL_INTERVAL=2.0

# STARLINK_GPS_POLL_INTERVAL  Seconds between GPS location updates
#                             (reverse geocoding + weather location update)
#                             Default: 300 (5 minutes)
# STARLINK_GPS_POLL_INTERVAL=300

# HISTORY_RETENTION_DAYS  Number of days of engine history to keep in SQLite.
#                         Older rows are deleted on service startup.
#                         Default: 365
# HISTORY_RETENTION_DAYS=365

# AUDIO_OUTPUT_DEVICE     PulseAudio sink name or ALSA device string.
#                         Defaults to system default audio output if not set.
# AUDIO_OUTPUT_DEVICE=

# DEV_MODE                1 = development mode (all page toggles enabled on startup)
#                         0 = production (default). docker-compose.yml sets this to 1
#                         automatically.
# DEV_MODE=0
